APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# Leave DATABASE_URL empty in dev to use SQLite automatically.
DATABASE_URL=
SQLITE_DB_PATH=./wata_smart_tracker.db

# Used automatically when APP_ENV=prod and DATABASE_URL is empty.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wata
POSTGRES_USER=wata
POSTGRES_PASSWORD=wata

JWT_SECRET=super-secret-key-with-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

AI_PROVIDER=ollama
AI_MODEL=qwen3.5:4b
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b

# In dev, localhost/127.0.0.1 with any port are also allowed automatically.
# Local AI setup:
# 1. Start Ollama with: ollama serve
# 2. Pull the model once with: ollama pull qwen3.5:4b